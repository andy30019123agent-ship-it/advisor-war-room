{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://advisor-war-room/schema/stock.schema.json",
  "title": "stocks/<id>.json（單股完整分析）",
  "description": "對應 docs/contracts/data-contract-v1.md 的 stocks/<id>.json 區塊。",
  "type": "object",
  "required": ["meta", "profile", "price", "primary_decision", "context", "evidence", "track", "forecast", "short_scenarios", "ohlc", "mid_long_reads"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schema_version", "data_date", "generated_at", "sources"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "integer" },
        "data_date": { "type": "string" },
        "generated_at": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } }
      }
    },
    "profile": {
      "type": "object",
      "required": ["id", "name", "market", "is_core_holding"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "market": { "type": "string" },
        "is_core_holding": { "type": "boolean" }
      }
    },
    "price": {
      "type": "object",
      "required": ["close", "change_pct", "ma20", "ma60"],
      "additionalProperties": false,
      "properties": {
        "close": { "type": ["number", "null"] },
        "change_pct": { "type": ["number", "null"] },
        "ma20": { "type": ["number", "null"] },
        "ma60": { "type": ["number", "null"] }
      }
    },
    "primary_decision": {
      "type": "object",
      "required": [
        "action", "stance", "position_delta", "confidence", "decided_by_layer",
        "reason_codes", "readable_reason", "risk_note", "position",
        "defense_price", "entry_condition", "reeval_date"
      ],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string" },
        "stance": { "type": "string" },
        "position_delta": {
          "type": "string",
          "enum": ["increase", "hold", "small_entry", "wait", "reduce", "exit"]
        },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "decided_by_layer": { "type": "integer", "minimum": 1, "maximum": 6 },
        "reason_codes": { "type": "array", "items": { "type": "string" } },
        "readable_reason": { "type": "string" },
        "risk_note": { "type": "string" },
        "position": {
          "type": "object",
          "required": ["tier_amount", "lots", "odd_shares"],
          "additionalProperties": false,
          "properties": {
            "tier_amount": { "type": "number" },
            "lots": { "type": "integer" },
            "odd_shares": { "type": "integer" }
          }
        },
        "defense_price": { "type": ["number", "null"] },
        "entry_condition": {
          "type": ["object", "null"],
          "required": ["price", "condition"],
          "additionalProperties": false,
          "properties": {
            "price": { "type": ["number", "null"] },
            "condition": { "type": "string" }
          }
        },
        "reeval_date": { "type": "string" },
        "core_note": { "type": "string" },
        "advice": {
          "type": "object",
          "required": ["holder", "nonholder"],
          "additionalProperties": false,
          "properties": {
            "holder": { "$ref": "#/definitions/advice_side" },
            "nonholder": { "$ref": "#/definitions/advice_side" }
          }
        },
        "defense_explain": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "required": ["timeframes", "lights", "valuation", "rr"],
      "additionalProperties": false,
      "properties": {
        "timeframes": {
          "type": "object",
          "required": ["short", "swing", "mid"],
          "additionalProperties": false,
          "properties": {
            "short": { "$ref": "#/definitions/timeframe" },
            "swing": { "$ref": "#/definitions/timeframe" },
            "mid": { "$ref": "#/definitions/timeframe" }
          }
        },
        "lights": {
          "type": "object",
          "required": ["fundamental", "technical", "chips"],
          "additionalProperties": false,
          "properties": {
            "fundamental": { "$ref": "#/definitions/light" },
            "technical": { "$ref": "#/definitions/light" },
            "chips": { "$ref": "#/definitions/light" }
          }
        },
        "valuation": {
          "type": "object",
          "required": ["band", "base", "bull", "bear", "regime", "warning"],
          "additionalProperties": false,
          "properties": {
            "band": {
              "type": ["string", "null"],
              "enum": ["便宜", "合理", "偏貴", "很貴", null]
            },
            "base": { "type": ["number", "null"] },
            "bull": { "type": ["number", "null"] },
            "bear": { "type": ["number", "null"] },
            "regime": { "type": ["string", "null"] },
            "warning": { "type": ["string", "null"] }
          }
        },
        "rr": { "type": ["number", "null"] }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["roles", "news", "events"],
      "additionalProperties": false,
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "support", "oppose", "verify"],
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string" },
              "support": { "type": "array", "items": { "type": "string" } },
              "oppose": { "type": "array", "items": { "type": "string" } },
              "verify": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "news": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "source", "url", "published_at"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "source": { "type": "string" },
              "url": { "type": "string" },
              "published_at": { "type": "string" }
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "label", "impact_note"],
            "additionalProperties": false,
            "properties": {
              "date": { "type": "string" },
              "label": { "type": "string" },
              "impact_note": { "type": "string" }
            }
          }
        }
      }
    },
    "track": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "action", "price_at_rec", "outcome", "status"],
        "additionalProperties": false,
        "properties": {
          "date": { "type": "string" },
          "action": { "type": "string" },
          "price_at_rec": { "type": "number" },
          "outcome": {
            "type": "object",
            "required": ["r5", "r20", "r60"],
            "additionalProperties": false,
            "properties": {
              "r5": { "type": ["number", "null"] },
              "r20": { "type": ["number", "null"] },
              "r60": { "type": ["number", "null"] }
            }
          },
          "status": { "type": "string", "enum": ["pending", "done"] }
        }
      }
    },
    "forecast": {
      "type": ["object", "null"],
      "required": [
        "method", "n_paths", "vol_annualized", "as_of", "history", "horizons",
        "week_range_70", "scenarios", "event_markers", "accuracy", "disclaimer"
      ],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string" },
        "n_paths": { "type": "integer" },
        "vol_annualized": { "type": "number" },
        "as_of": { "type": "string" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["d", "close"],
            "additionalProperties": false,
            "properties": {
              "d": { "type": "integer" },
              "close": { "type": "number" }
            }
          }
        },
        "horizons": {
          "type": "object",
          "required": ["m1", "m3", "m6"],
          "additionalProperties": false,
          "properties": {
            "m1": { "$ref": "#/definitions/horizon_block" },
            "m3": { "$ref": "#/definitions/horizon_block" },
            "m6": { "$ref": "#/definitions/horizon_block" }
          }
        },
        "week_range_70": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "scenarios": {
          "type": "object",
          "required": ["bear", "base", "bull"],
          "additionalProperties": false,
          "properties": {
            "bear": { "type": ["number", "null"] },
            "base": { "type": ["number", "null"] },
            "bull": { "type": ["number", "null"] }
          }
        },
        "event_markers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["d", "date", "label"],
            "additionalProperties": false,
            "properties": {
              "d": { "type": "integer" },
              "date": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "accuracy": {
          "type": "object",
          "required": ["n_evaluated", "hit_rate_70", "note"],
          "additionalProperties": false,
          "properties": {
            "n_evaluated": { "type": "integer" },
            "hit_rate_70": { "type": ["number", "null"] },
            "note": { "type": "string" }
          }
        },
        "disclaimer": { "type": "string" }
      }
    },
    "short_scenarios": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["status", "message"],
          "additionalProperties": false,
          "properties": {
            "status": { "const": "insufficient_data" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["status", "horizon", "key_levels", "scenarios", "prob_note", "disclaimer"],
          "additionalProperties": false,
          "properties": {
            "status": { "const": "ok" },
            "horizon": { "type": "string" },
            "key_levels": {
              "type": "object",
              "required": ["supports", "resistances"],
              "additionalProperties": false,
              "properties": {
                "supports": { "type": "array", "items": { "type": "number" }, "maxItems": 3 },
                "resistances": { "type": "array", "items": { "type": "number" }, "maxItems": 3 }
              }
            },
            "scenarios": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": { "$ref": "#/definitions/scenario" }
            },
            "prob_note": { "type": "string" },
            "disclaimer": { "type": "string" }
          }
        }
      ]
    },
    "ohlc": {
      "type": ["array", "null"],
      "minItems": 20,
      "maxItems": 60,
      "items": {
        "type": "object",
        "required": ["d", "o", "h", "l", "c", "v"],
        "additionalProperties": false,
        "properties": {
          "d": { "type": "string" },
          "o": { "type": "number" },
          "h": { "type": "number" },
          "l": { "type": "number" },
          "c": { "type": "number" },
          "v": { "type": "integer" }
        }
      }
    },
    "mid_long_reads": {
      "type": ["object", "null"],
      "required": ["swing", "mid"],
      "additionalProperties": false,
      "properties": {
        "swing": { "$ref": "#/definitions/mid_long_read_entry" },
        "mid": { "$ref": "#/definitions/mid_long_read_entry" }
      }
    }
  },
  "definitions": {
    "scenario": {
      "type": "object",
      "required": [
        "id", "title", "probability_pct", "trigger", "price_path",
        "price_path_text", "narrative", "invalidation", "action"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "enum": ["base", "risk", "bull"] },
        "title": { "type": "string" },
        "probability_pct": { "type": "integer" },
        "trigger": { "type": "string" },
        "price_path": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 3
        },
        "price_path_text": { "type": "string" },
        "narrative": { "type": "string" },
        "invalidation": { "type": "string" },
        "action": {
          "type": "object",
          "required": ["stance", "text"],
          "additionalProperties": false,
          "properties": {
            "stance": {
              "type": "string",
              "enum": ["increase", "hold", "small_entry", "wait", "reduce", "exit"]
            },
            "text": { "type": "string" }
          }
        }
      }
    },
    "horizon_block": {
      "type": "object",
      "required": ["days", "bands", "prob_range_70"],
      "additionalProperties": false,
      "properties": {
        "days": { "type": "integer" },
        "bands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["d", "p10", "p25", "p50", "p75", "p90"],
            "additionalProperties": false,
            "properties": {
              "d": { "type": "integer" },
              "p10": { "type": "number" },
              "p25": { "type": "number" },
              "p50": { "type": "number" },
              "p75": { "type": "number" },
              "p90": { "type": "number" }
            }
          }
        },
        "prob_range_70": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "advice_side": {
      "type": "object",
      "required": ["action_text", "plan"],
      "additionalProperties": false,
      "properties": {
        "action_text": { "type": "string" },
        "plan": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["trigger", "act"],
            "additionalProperties": false,
            "properties": {
              "trigger": { "type": "string" },
              "act": { "type": "string" }
            }
          }
        }
      }
    },
    "timeframe": {
      "type": "object",
      "required": ["label", "stance", "basis"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "stance": { "type": "string" },
        "basis": { "type": "string" }
      }
    },
    "light": {
      "type": "object",
      "required": ["color", "facts"],
      "additionalProperties": false,
      "properties": {
        "color": { "type": ["string", "null"], "enum": ["green", "yellow", "red", null] },
        "facts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mid_long_read_entry": {
      "type": "object",
      "required": ["bias", "path_text", "flip_condition", "basis"],
      "additionalProperties": false,
      "properties": {
        "bias": {
          "type": "string",
          "enum": ["偏多", "中性偏多", "中性", "中性偏空", "偏空"]
        },
        "path_text": { "type": "string" },
        "flip_condition": { "type": "string" },
        "basis": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 3
        }
      }
    }
  }
}
