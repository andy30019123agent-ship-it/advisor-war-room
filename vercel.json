{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "cd app && npm ci && npm run build && rm -rf dist/data && cp -r ../public/data dist/data",
  "outputDirectory": "app/dist",
  "functions": {
    "api/*.py": {
      "maxDuration": 30,
      "includeFiles": "{warroom/**,api/_lib/**,data/investor_profile.json,data/recommendation_log.json,public/data/daily.json,pyproject.toml}",
      "excludeFiles": "{app/**,.venv/**,.git/**,.github/**,design-system/**,mockups/**,reports/**,_reports/**,phase0/**,docs/**,tests/**,.pytest_cache/**,.impeccable/**,.superpowers/**,data/cache/**,node_modules/**,index.html,README.md}"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
